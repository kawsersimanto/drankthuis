{% doc %}
  A newsletter signup block that captures customer emails via Shopify's contact form.
{% enddoc %}
{{ 'newsletter-form.css' | asset_url | stylesheet_tag }}

<div class="newsletter-form-block tw:flex tw:flex-col tw:gap-4">
  {% form 'customer', id: 'newsletter-form' %}
    <input type="hidden" name="contact[tags]" value="newsletter">

    <div class="tw:flex tw:md:flex-row tw:flex-col tw:gap-3 tw:w-full">
      <input
        type="text"
        name="contact[first_name]"
        id="newsletter-first-name"
        placeholder="{{ block.settings.first_name_placeholder | default: 'First name' }}"
        required
        autocorrect="off"
        autocapitalize="words"
        class="tw:grow tw:shrink-0 tw:basis-0 tw:border tw:border-gray-300 tw:px-4 tw:py-3 tw:placeholder-slate-800! tw:text-slate-800! tw:text-base tw:outline-none tw:focus:ring-1 tw:bg-white! tw:rounded-full!"
      >
      <input
        type="email"
        name="contact[email]"
        id="newsletter-email"
        placeholder="{{ block.settings.placeholder | default: 'Enter your email' }}"
        required
        autocorrect="off"
        autocapitalize="off"
        class="tw:grow tw:shrink-0 tw:basis-0 tw:border tw:border-gray-300 tw:px-4 tw:py-3 tw:placeholder-slate-800! tw:text-slate-800! tw:text-base tw:outline-none tw:focus:ring-1 tw:bg-white! tw:rounded-full!"
      >

      <button
        type="submit"
        class="tw:bg-[#2ed9e6] tw:text-black! tw:px-6 tw:py-4 tw:rounded-full tw:text-base tw:cursor-pointer tw:grow-0 tw:shrink tw:basis-0"
      >
        {{ block.settings.button_label | default: 'Subscribe' }}
      </button>
    </div>

    {% if form.errors %}
      <div class="tw:text-red-500 tw:text-sm tw:mt-2">
        {{ form.errors | default_errors }}
      </div>
    {% endif %}

    {% if form.posted_successfully? %}
      <div class="tw:text-green-600 tw:text-sm tw:mt-2">
        {{ block.settings.success_message | default: 'Thanks for subscribing!' }}
      </div>
    {% endif %}
  {% endform %}
</div>

{% schema %}
{
  "name": "Newsletter Form",
  "class": "newsletter-customer-block",
  "settings": [
    {
      "type": "text",
      "id": "first_name_placeholder",
      "label": "First Name Placeholder",
      "default": "First name"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success Message",
      "default": "Thanks for subscribing!"
    }
  ],
  "presets": [
    {
      "name": "Newsletter Form"
    }
  ]
}
{% endschema %}
