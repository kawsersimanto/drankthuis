<script src="{{ 'review-slider.js' | asset_url }}" defer></script>

<review-slider
  class="tw:block tw:w-full"
  id="review-slider-{{ block.id }}"
  data-loop="{{ block.settings.loop }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  data-navigation="{{ block.settings.show_navigation }}"
  data-pagination="{{ block.settings.show_pagination }}"
  {{ block.shopify_attributes }}
>
  <div
    class="swiper tw:max-w-280 tw:w-90 tw:md:w-2xl tw:lg:w-280"
    data-slides-mobile="{{ block.settings.slides_mobile }}"
    data-slides-tablet="{{ block.settings.slides_sm }}"
    data-slides-desktop="{{ block.settings.slides_lg }}"
    data-space-between="24"
  >
    <div class="swiper-wrapper">
      {%- for review in shop.metaobjects.reviews.values -%}
        {%- liquid
          assign customer_name = review.customer_name.value
          assign description = review.description
          assign rating_obj = review.rating
          assign rating_value = rating_obj.rating | plus: 0
          assign rating_max = rating_obj.scale_max | default: 5 | plus: 0
        -%}

        <div class="swiper-slide">
          <article
            class="tw:flex tw:flex-col tw:items-center tw:justify-center tw:gap-2"
            aria-label="Review by {{ customer_name | escape }}"
          >
            {%- if rating_obj != blank -%}
              <div
                class="tw:flex tw:items-center tw:gap-1"
                role="img"
                aria-label="{{ rating_value }} out of {{ rating_max }} stars"
              >
                {%- for i in (1..rating_max) -%}
                  <svg
                    class="tw:w-5 tw:h-5 tw:shrink-0"
                    viewBox="0 0 20 20"
                    aria-hidden="true"
                  >
                    <path
                      fill="#e2bd37"
                      d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"
                    />
                  </svg>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if description != blank -%}
              <div class="tw:flex-1">
                <p class="tw:text-gray-600 tw:text-sm tw:line-clamp-4 tw:text-center">
                  {{ description | escape | newline_to_br }}
                </p>
              </div>
            {%- endif -%}

            <header class="tw:flex tw:items-center tw:gap-3">
              <h3 class="tw:text-lg! tw:uppercase!">
                {{ customer_name | escape }}
              </h3>
            </header>
          </article>
        </div>

      {%- else -%}
        <p class="tw:text-center tw:text-gray-400 tw:text-sm tw:py-8 tw:w-full">
          No reviews found. Add entries to your <strong>reviews</strong> Metaobject.
        </p>
      {%- endfor -%}
    </div>
  </div>
</review-slider>

{% schema %}
{
  "name": "Review Slider",
  "settings": [
    {
      "type": "range",
      "id": "slides_mobile",
      "label": "Slides per view (mobile)",
      "min": 1,
      "max": 2,
      "step": 0.5,
      "default": 1
    },
    {
      "type": "range",
      "id": "slides_sm",
      "label": "Slides per view (tablet)",
      "min": 1,
      "max": 3,
      "step": 0.5,
      "default": 2
    },
    {
      "type": "range",
      "id": "slides_lg",
      "label": "Slides per view (desktop)",
      "min": 1,
      "max": 4,
      "step": 0.5,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Enable loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay speed (ms)",
      "min": 2000,
      "max": 8000,
      "step": 500,
      "default": 4000
    }
  ],
  "presets": [
    {
      "name": "Review Slider"
    }
  ]
}
{% endschema %}
