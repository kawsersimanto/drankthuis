{%- if settings.shipping_progress_bar_enabled and settings.cart_type == 'drawer' -%}
  {%- liquid
    assign minimum_cents = settings.shipping_progress_bar_minimum_amount | times: 100
    assign threshold_cents = settings.shipping_progress_bar_threshold | times: 100
    assign current_total = cart.total_price

    assign remaining_to_minimum = minimum_cents | minus: current_total
    assign remaining_to_free = threshold_cents | minus: current_total

    if current_total >= threshold_cents
      assign bar_state = 'free-shipping'
      assign progress_percentage = 100
    elsif current_total >= minimum_cents
      assign bar_state = 'above-minimum'
      assign progress_percentage = current_total | times: 100 | divided_by: threshold_cents
      assign progress_percentage = progress_percentage | at_most: 100
    else
      assign bar_state = 'below-minimum'
      assign progress_percentage = current_total | times: 100 | divided_by: threshold_cents
      assign progress_percentage = progress_percentage | at_most: 100
    endif

    if current_total == 0
      assign progress_percentage = 2
    endif

    assign success_message = 'content.free_shipping_unlocked' | t
  -%}

  {% if cart != empty %}
    <link
      rel="stylesheet"
      href="{{ 'shipping-progress-bar.css' | asset_url }}"
      fetchpriority="low"
    >
    <script
      src="{{ 'shipping-progress-bar.js' | asset_url }}"
      type="module"
      fetchpriority="low"
    ></script>

    <shipping-progress-bar
      class="shipping-progress-bar"
      data-minimum="{{ minimum_cents }}"
      data-threshold="{{ threshold_cents }}"
      data-current-total="{{ current_total }}"
      data-success-message="{{ success_message }}"
      data-state="{{ bar_state }}"
      {% if bar_state == 'free-shipping' %}
        data-threshold-reached
      {% endif %}
    >
      <div class="shipping-progress-bar__container">
        <div
          class="shipping-progress-bar__track"
          style="--progress: {{ progress_percentage }}%"
          data-state="{{ bar_state }}"
        >
          <div
            class="shipping-progress-bar__fill"
            role="progressbar"
            aria-valuenow="{{ progress_percentage }}"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-label="{{ 'accessibility.shipping_progress' | t }}"
            ref="fill"
          ></div>
          {{- 'icon-shipping-truck.svg' | inline_asset_content -}}
        </div>

        <p
          class="shipping-progress-bar__message cart-primary-typography{% if bar_state == 'free-shipping' %} shipping-progress-bar__message--success{% endif %}"
          ref="message"
        >
          {%- if bar_state == 'free-shipping' -%}
            You get Free Delivery!!!
          {%- elsif bar_state == 'above-minimum' -%}
            Only {{ remaining_to_free | money }} away from Free Delivery
          {%- else -%}
            Only {{ remaining_to_minimum | money }} away from Minimum order
          {%- endif -%}
        </p>
      </div>
    </shipping-progress-bar>
  {% endif %}
{%- endif -%}
